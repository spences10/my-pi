{
	"name": "my-pi",
	"version": "0.1.8",
	"description": "Composable pi coding agent with MCP, LSP, agent chains, prompt presets, and local eval telemetry",
	"keywords": [
		"cli",
		"coding-agent",
		"evals",
		"lsp",
		"mcp",
		"pi",
		"pi-package",
		"sqlite",
		"telemetry"
	],
	"homepage": "https://github.com/spences10/my-pi#readme",
	"bugs": {
		"url": "https://github.com/spences10/my-pi/issues"
	},
	"license": "MIT",
	"author": "Scott Spence <spences10apps@gmail.com>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/spences10/my-pi.git"
	},
	"bin": {
		"my-pi": "./dist/index.js"
	},
	"files": [
		"dist",
		"src/extensions",
		"themes",
		"README.md"
	],
	"type": "module",
	"main": "./dist/api.js",
	"exports": {
		".": "./dist/api.js",
		"./cli": "./dist/index.js"
	},
	"scripts": {
		"build": "pnpm --filter \"./packages/*\" run build && vp pack",
		"dev": "vp pack --watch",
		"start": "node ./dist/index.js",
		"check": "pnpm --filter \"./packages/*\" run build && vp check && pnpm --filter \"./packages/*\" run check",
		"check:fix": "vp check --fix",
		"format": "vp check --fix",
		"test": "pnpm --filter \"./packages/*\" run build && sh -c 'if [ \"$#\" -gt 0 ]; then vp test \"$@\"; else vp test && pnpm --filter \"./packages/*\" run test; fi' --",
		"test:watch": "vp test watch",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm run build && changeset publish"
	},
	"dependencies": {
		"@mariozechner/pi-ai": "^0.70.2",
		"@mariozechner/pi-coding-agent": "^0.70.2",
		"@mariozechner/pi-tui": "^0.70.2",
		"@spences10/pi-lsp": "workspace:*",
		"@spences10/pi-mcp": "workspace:*",
		"@spences10/pi-nopeek": "workspace:*",
		"@spences10/pi-recall": "workspace:*",
		"@spences10/pi-redact": "workspace:*",
		"@spences10/pi-skills": "workspace:*",
		"@spences10/pi-telemetry": "workspace:*",
		"citty": "^0.2.2",
		"typebox": "^1.1.33"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@types/node": "^25.6.0",
		"vite-plus": "^0.1.19",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@10.33.2",
	"pi": {
		"themes": [
			"./themes"
		]
	}
}
